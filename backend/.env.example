# Database (SQLite — default path: ~/.openclaw/clawcontrol/clawcontrol.db)
# DATABASE_URL=sqlite:////path/to/clawcontrol.db

# OpenClaw gateway
GATEWAY_URL=http://localhost:18789
HOOKS_TOKEN=

# CORS — comma-separated extra origins (e.g. http://192.168.x.x:5174)
CORS_EXTRA_ORIGINS=

# Base directory for all OpenClaw data (default: ~/.openclaw)
# OPENCLAW_HOME=~/.openclaw

# ClawControl API URL (used by worker scripts)
CLAWCONTROL_URL=http://127.0.0.1:8088
